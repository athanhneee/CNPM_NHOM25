generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String          @id @default(uuid())
  code                  String?
  username              String          @unique
  email                 String          @unique
  fullName              String
  phone                 String?
  secondaryEmail        String?
  roles                 Json
  status                AccountStatus   @default(ACTIVE)
  passwordDigest        String
  failedLoginAttempts   Int             @default(0)
  lastLoginAt           DateTime?
  campus                String?
  department            String?
  dateOfBirth           DateTime?
  gender                String?
  citizenId             String?
  nationality           String?
  ethnicity             String?
  religion              String?
  birthPlace            String?
  address               String?
  homeTown              String?
  program               String?
  cohort                String?
  faculty               String?
  majorCode             String?
  majorName             String?
  studentClass          String?
  educationProgram      String?
  academicPeriod        String?
  studentStatus         String?
  classificationStatus  String?
  title                 String?
  position              String?
  specialization        String?
  yearLevel             String?
  gpa                   Float?
  attendanceRate        Float?
  completedCredits      Int?
  interests             Json?
  assignedSectionIds    Json?
  bio                   String?
  avatarUrl             String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  registrationLocked    Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  auditLogs             AuditLog[]
  enrollments           Enrollment[]
  lectures              Section[]       @relation("LecturerSections")
  studentResults        StudentResult[]
  wishRequests          WishRequest[]

  @@index([status])
}

model Course {
  id                         String            @id @default(uuid())
  code                       String            @unique
  name                       String
  credits                    Int
  status                     CourseStatus      @default(ACTIVE)
  department                 String
  campus                     String
  description                String
  prerequisites              Json              @default("[]")
  prestudy                   Json              @default("[]")
  corequisites               Json              @default("[]")
  category                   CourseCategory
  faculty                    String?
  courseType                 String?
  academicBlock              String?
  suggestedSemester          Int?
  lectureHours               Int?
  practiceHours              Int?
  labHours                   Int?
  passingScore               Float?
  maxStudents                Int?
  classSectionCount          Int?
  gradingWeight              Json?
  majorsSupported            Json?
  majorCodesSupported        Json?
  track                      String?
  applicableSpecializations  Json?
  requiredAccumulatedCredits Int?              @default(0)
  conditions                 CourseCondition[] @relation("CourseConditions")
  requiredByConditions       CourseCondition[] @relation("RequiredCourseConditions")
  sections                   Section[]
  studentResults             StudentResult[]
  ElectiveGroup              ElectiveGroup[]   @relation("CourseElectiveGroups")

  @@index([status])
  @@index([department])
}

model SemesterOption {
  id                 String                      @id @default(uuid())
  label              String
  isCurrent          Boolean                     @default(false)
  academicYear       String?
  termCode           String?
  registrationStatus SemesterRegistrationStatus?
  registrationStart  DateTime?
  registrationEnd    DateTime?
  adjustmentStart    DateTime?
  adjustmentEnd      DateTime?
  type               SemesterType                @default(MAIN)
  endDate            DateTime?
  startDate          DateTime?
  enrollments        Enrollment[]
  phases             RegistrationPhase[]
  sections           Section[]
  studentResults     StudentResult[]
  systemSettings     SystemSetting[]
  wishRequests       WishRequest[]

  @@index([isCurrent])
}

model Section {
  id                  String         @id @default(uuid())
  sectionCode         String
  courseCode          String
  semesterId          String
  group               String
  subGroup            String
  lecturerId          String
  room                String
  weekday             Int
  startPeriod         Int
  periodCount         Int
  weeks               String
  capacity            Int
  registeredCount     Int            @default(0)
  waitlistCount       Int            @default(0)
  allowWaitlist       Boolean        @default(true)
  status              SectionStatus  @default(OPEN)
  campus              String
  notes               String?
  examSlot            String?
  roomId              String?
  additionalSchedules Json?          @default("[]")
  cancelledDates      Json?          @default("[]")
  makeUpSchedules     Json?          @default("[]")
  minCapacity         Int            @default(0)
  startDate           DateTime?
  endDate             DateTime?
  learningMode        LearningMode   @default(OFFLINE)
  enrollments         Enrollment[]
  course              Course         @relation(fields: [courseCode], references: [code])
  lecturer            User           @relation("LecturerSections", fields: [lecturerId], references: [id])
  roomRef             Room?          @relation(fields: [roomId], references: [id])
  semester            SemesterOption @relation(fields: [semesterId], references: [id])

  @@unique([sectionCode, semesterId])
  @@index([courseCode])
  @@index([semesterId])
  @@index([lecturerId])
  @@index([roomId])
  @@index([status])
}

model Room {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  capacity  Int
  campus    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sections  Section[]
}

model CourseCondition {
  id                 String              @id @default(uuid())
  courseCode         String
  requiredCourseCode String
  type               CourseConditionType
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  course             Course              @relation("CourseConditions", fields: [courseCode], references: [code], onDelete: Cascade)
  requiredCourse     Course              @relation("RequiredCourseConditions", fields: [requiredCourseCode], references: [code])

  @@unique([courseCode, requiredCourseCode, type])
  @@index([courseCode])
  @@index([requiredCourseCode])
  @@index([type])
}

model Enrollment {
  id               String           @id @default(uuid())
  studentId        String
  sectionId        String
  semesterId       String
  status           EnrollmentStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  cancelledAt      DateTime?
  droppedAt        DateTime?
  reasonCode       String?
  waitlistOrder    Int?
  timeline         Json             @default("[]")
  isImprovement    Boolean          @default(false)
  isRetake         Boolean          @default(false)
  hasPartialGrades Boolean          @default(false)
  isMandatory      Boolean          @default(false)
  tuitionStatus    String           @default("UNPAID")
  section          Section          @relation(fields: [sectionId], references: [id])
  semester         SemesterOption   @relation(fields: [semesterId], references: [id])
  student          User             @relation(fields: [studentId], references: [id])

  @@index([studentId, semesterId])
  @@index([sectionId])
  @@index([status])
}

model StudentResult {
  id           String              @id @default(uuid())
  studentId    String
  courseCode   String
  semesterId   String?
  letterGrade  String?
  numericGrade Float?
  status       StudentResultStatus
  passed       Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  course       Course              @relation(fields: [courseCode], references: [code])
  semester     SemesterOption?     @relation(fields: [semesterId], references: [id])
  student      User                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseCode])
  @@index([semesterId])
  @@index([passed])
}

model RegistrationErrorCode {
  code        String   @id
  message     String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WishRequest {
  id             String         @id @default(uuid())
  studentId      String
  semesterId     String
  courseCode     String
  preferredGroup String?
  reason         String
  createdAt      DateTime       @default(now())
  status         WishStatus     @default(PENDING)
  semester       SemesterOption @relation(fields: [semesterId], references: [id])
  student        User           @relation(fields: [studentId], references: [id])

  @@index([studentId, semesterId])
  @@index([status])
}

model AuditLog {
  id        String      @id @default(uuid())
  timestamp DateTime    @default(now())
  actorId   String
  actorRole UserRole
  action    String
  targetId  String
  result    AuditResult
  message   String
  metadata  Json?
  actor     User        @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetId])
  @@index([result])
}

model SystemSetting {
  id                         Int            @id @default(1)
  simulationNow              DateTime
  registrationStart          DateTime
  registrationEnd            DateTime
  adjustmentStart            DateTime
  adjustmentEnd              DateTime
  withdrawalDeadline         DateTime
  minCredits                 Int
  maintenanceMode            Boolean
  allowWaitlist              Boolean
  sessionTimeoutMinutes      Int
  warningBeforeLogoutSeconds Int
  maxClassesPerDay           Int
  maxClassesPerSemester      Int
  currentSemesterId          String
  maintenanceMessage         String
  allowGradeImprovement      Boolean        @default(true)
  maxCreditsMain             Int            @default(24)
  maxCreditsSummer           Int            @default(12)
  maxRetakeAttempts          Int            @default(3)
  countWaitlistCredits       Boolean        @default(false)
  currentSemester            SemesterOption @relation(fields: [currentSemesterId], references: [id])
}

model ElectiveGroup {
  id         String   @id
  code       String   @unique
  name       String
  majorCode  String?
  minCredits Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Course     Course[] @relation("CourseElectiveGroups")
}

model RegistrationPhase {
  id             String         @id
  semesterId     String
  name           String
  startDate      DateTime
  endDate        DateTime
  allowedCohorts Json?
  allowedMajors  Json?
  maxCredits     Int?
  allowRegister  Boolean        @default(true)
  allowCancel    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  SemesterOption SemesterOption @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@index([semesterId])
}

enum UserRole {
  STUDENT
  LECTURER
  ACADEMIC_OFFICE
  ADMIN
}

enum SemesterType {
  MAIN
  SUMMER
}

enum AccountStatus {
  ACTIVE
  LOCKED
  INACTIVE
  DEFERRED
  SUSPENDED
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum CourseCategory {
  FOUNDATION
  CORE
  ELECTIVE
  THESIS
}

enum EnrollmentStatus {
  PENDING
  REGISTERED
  CANCELLED
  REJECTED
  COMPLETED
  FAILED
  WAITLISTED
  DROPPED
}

enum SectionStatus {
  OPEN
  CLOSED
  FULL
  CANCELLED
  IN_PROGRESS
  COMPLETED
}

enum WishStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
  CANCELLED
}

enum AuditResult {
  SUCCESS
  FAILURE
  WARNING
  INFO
}

enum SemesterRegistrationStatus {
  UPCOMING
  OPEN
  ADJUSTMENT
  CLOSED
  COMPLETED
}

enum CourseConditionType {
  PREREQUISITE
  PRESTUDY
  COREQUISITE
  EQUIVALENT
  REPLACEMENT
}

enum StudentResultStatus {
  PASSED
  FAILED
  IN_PROGRESS
  TRANSFERRED
  WITHDRAWN
}

enum LearningMode {
  OFFLINE
  ONLINE
  BLENDED
}
